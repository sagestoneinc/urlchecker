# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# VirusTotal API key (required)
VT_API_KEY=your_virustotal_api_key_here

# Telegram bot token (optional – required for alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat ID (optional – required for alerts)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Path to the URL list file (default: urls.txt)
URLS_FILE=urls.txt

# Directory where results are stored (default: results)
RESULTS_DIR=results

# VirusTotal polling interval in seconds (default: 15)
VT_POLL_INTERVAL=15

# Maximum number of polling attempts per URL (default: 10)
VT_POLL_MAX_ATTEMPTS=10

# HTTP request timeout in seconds (default: 30)
VT_REQUEST_TIMEOUT=30

# Maximum HTTP retry attempts (default: 3)
VT_MAX_RETRIES=3

# VirusTotal API rate limit (requests per minute, free tier = 4)
VT_RATE_LIMIT_RPM=4

# Optional URLScan.io scanner (disabled by default)
ENABLE_URLSCAN_IO=false
URLSCAN_IO_API_KEY=
# URLScan.io public API default throughput
URLSCAN_IO_RPS=2
# URLScan.io scan visibility (e.g., unlisted/public)
URLSCAN_IO_VISIBILITY=unlisted

# Send a Telegram alert when a previously bad URL becomes clean (default: false)
ALERT_ON_CLEAN=false

# Send a summary Telegram message at the end of each run (default: true)
SEND_SUMMARY=true

# Label shown in summary report output (default shown below)
REPORT_SOURCES_CHECKED=Browser logs, spam reports, customer tickets

# ------------------------------------------------------------------
# Optional Hubstaff Telegram Task Bot subsystem (OFF by default)
# ------------------------------------------------------------------

# Enable optional task bot runtime (default: false)
ENABLE_HUBSTAFF_TASKS_BOT=true

# Hubstaff API base URL
HUBSTAFF_API_BASE_URL=https://api.hubstaff.com

# Hubstaff Personal Access Token / OAuth access token
HUBSTAFF_TOKEN=

# Hubstaff HTTP timeout and retries
HUBSTAFF_TIMEOUT_SECONDS=30
HUBSTAFF_MAX_RETRIES=3

# Optional comma-separated done status IDs for task completion fallback
# Example: HUBSTAFF_DONE_STATUS_IDS=123,456
HUBSTAFF_DONE_STATUS_IDS=

# Telegram task-bot polling behavior
TASKBOT_POLL_TIMEOUT_SECONDS=30
TASKBOT_POLL_INTERVAL_SECONDS=2

# Persistent task-bot state file
TASKBOT_STATE_FILE=results/taskbot_state.json

# Default timezone for reminders
TASKBOT_DEFAULT_TIMEZONE=UTC

# Optional JSON mapping from Telegram user id to Hubstaff user id
# Example: TASKBOT_USER_MAPPING_JSON={"123456789":"42"}
TASKBOT_USER_MAPPING_JSON={}
